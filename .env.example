# HuggingFace token required for diarization
# 1. Accept the terms : https://hf.co/pyannote/speaker-diarization-3.1
# 2. Accept the terms : https://hf.co/pyannote/segmentation-3.0
# 3. Create a token   : https://hf.co/settings/tokens
# 4. Copy this file to .env and paste your token below
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Diarization tuning (optional — defaults shown) ───────────────────────────
#
# DIAR_MATCH_THRESHOLD
#   Cosine similarity required to match a new voice embedding to a known speaker.
#   Lower  → more permissive (same person recognised across more conditions).
#   Higher → stricter (reduces risk of merging two different people).
#   Raise this value if two different speakers are being merged into one.
#   Lower this value if the same speaker keeps appearing as multiple SPEAKER_ IDs.
#   Recommended range: 0.15 – 0.40   Default: 0.25
#DIAR_MATCH_THRESHOLD=0.25

# DIAR_MERGE_THRESHOLD
#   Cosine similarity above which two accumulated speaker centroids are considered
#   the same person and merged post-hoc after each audio chunk.
#   Must always be higher than DIAR_MATCH_THRESHOLD.
#   Raise this value if two clearly distinct speakers are being merged.
#   Recommended range: 0.60 – 0.85   Default: 0.70
#DIAR_MERGE_THRESHOLD=0.70

# DIAR_MIN_SEGMENT_S
#   Minimum speaker turn duration (seconds) from which a voice embedding is
#   extracted. Very short turns produce noisy embeddings. Increase if you see
#   many false new speakers; decrease only if speakers tend to use very short turns.
#   Recommended range: 0.5 – 2.0   Default: 1.0
#DIAR_MIN_SEGMENT_S=1.0

# DIAR_CONTEXT_S
#   Seconds of audio kept from the end of the previous chunk and prepended to
#   the current diarization window. Provides continuity across chunk boundaries
#   so the model can recognise who was speaking at the start of each new chunk.
#   Recommended range: 1.0 – 4.0   Default: 2.0
#DIAR_CONTEXT_S=2.0
